# =============================================================================
# AI-Pandit — Environment Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ---- App ----
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://agentic-ai-pandit-ai-pandits-projects.vercel.app

# ---- Database (PostgreSQL) ----
# Local (via docker-compose):
NEON_DATABASE_URL=postgresql+asyncpg://ai_pandit:ai_pandit_dev@localhost:5432/ai_pandit
# Production (Neon/Cloud SQL):
# NEON_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db?ssl=require

# ---- Redis ----
# Local (via docker-compose):
REDIS_URL=redis://localhost:6379/0
REDIS_TLS=false
# Production (Upstash / Redis Cloud):
# REDIS_URL=rediss://default:pass@host:6379
# REDIS_TLS=true

# ---- Auth (Clerk) ----
CLERK_SECRET_KEY=sk_test_placeholder

# ---- AI Providers (Vertex AI — GCP native auth, no API key needed) ----
VERTEX_FLASH_MODEL=gemini-2.5-flash-preview-04-17
VERTEX_PRO_MODEL=gemini-2.5-pro-preview-03-25

# ---- Encryption ----
# At least 32 characters:
ENCRYPTION_SECRET=development_secret_key_32chars!!

# ---- Google Cloud (optional) ----
GOOGLE_CLOUD_PROJECT=agentic-ai-pandit
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ---- Observability ----
SENTRY_DSN=
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
