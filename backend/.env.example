# ==========================================
# AI-PANDIT (AGENTIC) - ENVIRONMENT VARIABLES
# ==========================================
# Copy to .env and fill all values before running.

# ==========================================
# APPLICATION
# ==========================================
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
APP_NAME=ai-pandit-agentic
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://agentic-ai-pandit-ai-pandits-projects.vercel.app

# ==========================================
# DATABASE (Neon PostgreSQL)
# ==========================================
# NOTE: The driver prefix must match SQLAlchemy's async dialect.
#   psycopg[binary] → postgresql+psycopg://  (no extra install needed)
#   asyncpg          → postgresql+asyncpg://  (requires `pip install asyncpg`)
NEON_DATABASE_URL=postgresql+psycopg://user:password@ep-example.region.aws.neon.tech/dbname?sslmode=require

# ==========================================
# REDIS (Upstash — cache + queue + event store)
# ==========================================
REDIS_URL=rediss://default:password@host.upstash.io:6379
REDIS_TLS=true
REDIS_QUEUE_NAME=ai-pandit:agentic:jobs

# ==========================================
# AUTHENTICATION (Clerk)
# ==========================================
CLERK_SECRET_KEY=sk_live_xxxxxxxxx

# ==========================================
# AI PROVIDERS (Vertex AI only — GCP native auth on Cloud Run)
# ==========================================
# No API key needed — authentication is automatic via GCP service account
VERTEX_FLASH_MODEL=gemini-2.5-flash-preview-04-17
VERTEX_PRO_MODEL=gemini-2.5-pro-preview-03-25

# ==========================================
# ENCRYPTION
# ==========================================
ENCRYPTION_SECRET=your_64_char_hex_encryption_secret

# ==========================================
# EPHEMERIS SERVICE (Modified Skyfield — existing deployment)
# ==========================================
EPHEMERIS_SERVICE_URL=http://localhost:8000
EPHEMERIS_SERVICE_TIMEOUT_MS=15000
EPHEMERIS_BATCH_SIZE=250
EPHEMERIS_HOUSE_SYSTEM=whole_sign

# ==========================================
# GOOGLE CLOUD
# ==========================================
GOOGLE_CLOUD_PROJECT=agentic-ai-pandit
GOOGLE_CLOUD_TASKS_QUEUE=btr-jobs
GOOGLE_CLOUD_STORAGE_BUCKET=agentic-ai-pandit-btr-archive

# ==========================================
# OBSERVABILITY
# ==========================================
SENTRY_DSN=https://xxxxxxxxx@sentry.io/xxxxxx
OTEL_ENABLED=false
OTEL_SERVICE_NAME=ai-pandit-agentic

# ==========================================
# FEATURE FLAGS
# ==========================================
USE_ASYNC_JOB_PIPELINE=true
JOB_EXECUTION_MODE=inline

# ==========================================
# RESOURCE MANAGEMENT
# ==========================================
MAX_CONCURRENT_SESSIONS=3
MAX_ACTIVE_JOBS_PER_USER=2
LOAD_SHED_QUEUE_DEPTH=80
